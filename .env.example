# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# Contact form email delivery (existing)
RESEND_API_KEY=

# Stripe — server-side
STRIPE_SECRET_KEY=
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# Stripe — browser-safe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe — webhook signing secret
# Production: get from https://dashboard.stripe.com/webhooks → your endpoint → "Signing secret"
# Local dev: get from `stripe listen --forward-to localhost:3000/api/webhook`
STRIPE_WEBHOOK_SECRET=
